-- QUERY 1
-- Retrieve names of students enrolled in any society

SELECT StudentName
FROM STUDENT
WHERE RollNo IN (
    SELECT RollNo
    FROM ENROLLMENT
);




-- QUERY 2
-- Retrieve all society names

SELECT SocName
FROM SOCIETY;




-- QUERY 3
-- Retrieve students' names starting with the letter 'A'

SELECT StudentName
FROM STUDENT
WHERE StudentName LIKE 'A%';




-- QUERY 4
-- Retrieve students' details studying in courses 'computer science' or 'chemistry'

SELECT *
FROM STUDENT
WHERE Course='CS'
OR Course='Chem';




-- QUERY 5
-- Retrieve students' names whose roll no either starts with 'X' or 'Z' and ends with '9'

SELECT StudentName
FROM STUDENT
WHERE (RollNo LIKE 'X%9'
OR RollNo LIKE 'Z%9');




-- QUERY 6
-- Find society details with more than N TotalSeats where N is input by the user

SELECT *
FROM SOCIETY
WHERE TotalSeats > 30;




-- QUERY 7
-- Update society table for the mentor name of a specific society

UPDATE SOCIETY
SET MentorName='Agarwal'
WHERE SocName='NSS';




-- QUERY 8
-- Find society names in which more than five students have enrolled

SELECT SID, COUNT(RollNo)
FROM ENROLLMENT
GROUP BY SID
HAVING COUNT(RollNo) > 5;




-- QUERY 9
-- Find the name of the youngest student enrolled in society 'NSS'

SELECT StudentName
FROM STUDENT
WHERE DOB = (
    SELECT MAX(DOB)
    FROM STUDENT
    WHERE RollNo IN (
        SELECT RollNo
        FROM ENROLLMENT
        WHERE SID = (
            SELECT SocID
            FROM SOCIETY
            WHERE SocName='NSS'
        )
    )
);




-- QUERY 10
-- Find the name of the most popular society
-- (on the basis of enrolled students)

SELECT SID, COUNT(RollNo)
FROM ENROLLMENT
GROUP BY SID
ORDER BY COUNT(RollNo) DESC
LIMIT 1;
